# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "From" address for outgoing contact form emails.
# Must be a verified domain in Resend (e.g. noreply@sprinklermedic.com).
RESEND_FROM_EMAIL=noreply@sprinklermedic.com

# ─── Google Analytics 4 ──────────────────────────────────────────────────────
# Measurement ID from GA4 property settings (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Google Tag Manager ──────────────────────────────────────────────────────
# Container ID from GTM (format: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_CONTAINER_ID=GTM-XXXXXXX

# ─── Google Search Console ───────────────────────────────────────────────────
# Verification token from Search Console > Settings > Ownership verification
# (HTML tag method — just the content value, not the full meta tag)
NEXT_PUBLIC_GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
